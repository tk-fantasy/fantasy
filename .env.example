# ========================================
# Aether Demo 环境配置示例
# ========================================
# 复制本文件为 .env 并填入真实值
# .env 已被 .gitignore 忽略，不会上传

# ========================================
# LLM API 密钥
# ========================================
# 注意：LLM 密钥推荐通过前端 UI（/keys 页面）管理
# 前端添加的密钥会自动写入 .env 文件
# 以下示例对应 config.json 中 llm_keys 的 api_key_env 字段

# 智谱 GLM 系列（chat/vision/summary）
ZHIPU_API_KEY_2=your_zhipu_api_key_here

# SiliconFlow（embed 模型）
LLM_KEY_API_C12091=your_siliconflow_api_key_here

# 其他 provider 的密钥
LLM_KEY_OPEN_F2EF5B=
LLM_KEY_OPEN_FCC2A5=

# ========================================
# 可选配置
# ========================================

# 接口访问令牌（JWT 模式，留空则不启用）
# 设置后所有 /api 和 /ws 请求需带 Authorization: Bearer <token>
APP_TOKEN=

# 知识图谱 pipeline 路径（可选，用于 RAG 语义搜索）
# KG_PIPELINE_PATH=/path/to/kg-pipeline

# 文档目录（可选，用于 RAG 索引构建）
# DOCS_ROOT=/path/to/docs

# 语音识别 STT（SiliconFlow SenseVoiceSmall，/chat /doc 麦克风按钮）
# STT Key 已纳入 llm_keys 体系：在 /keys 页面添加 type=stt 的 Key 即可，
# 保存后 env 变量名（SILICONFLOW_STT_KEY）会指向此处填写的值。
SILICONFLOW_STT_KEY=

# ========================================
# 系统级配置（在 config.json 中管理）
# ========================================
# 以下配置在 config.json 中管理，不需要在 .env 中设置：
# - HA 连接：ha.url, ha.token
# - 天气 API：weather.host, weather.kid, weather.sub, weather.private_key
# - 网页搜索：web_search.exa.api_key（留空匿名调用 Exa MCP）
# - 视觉参数：vision.*
# - RAG 参数：rag.*
# - 家庭信息：home.*
